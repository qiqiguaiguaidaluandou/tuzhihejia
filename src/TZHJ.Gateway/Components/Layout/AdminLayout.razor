@inherits LayoutComponentBase

<div class="layout">
    <div class="side">
        <div class="brand">图纸核价 · 管理后台</div>
        <NavLink href="admin/users" Match="NavLinkMatch.Prefix">用户管理</NavLink>
        <NavLink href="admin/roles" Match="NavLinkMatch.Prefix">角色管理</NavLink>
        <NavLink href="admin/schedules" Match="NavLinkMatch.Prefix">采集计划</NavLink>
        <NavLink href="admin/logs" Match="NavLinkMatch.Prefix">操作日志</NavLink>
        <div class="spacer"></div>
        <AuthorizeView>
            <Authorized>
                <div class="who">
                    当前：@context.User.Identity?.Name
                    <form method="post" action="/admin/logout" style="margin-top:8px;">
                        <button class="ghost" type="submit" style="width:100%;">退出登录</button>
                    </form>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>
    <div class="main">
        @Body
    </div>
</div>
