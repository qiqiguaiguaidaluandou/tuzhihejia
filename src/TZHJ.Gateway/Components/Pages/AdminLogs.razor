@page "/admin/logs"
@attribute [Authorize(Policy = "AdminOnly")]
@rendermode InteractiveServer
@inject IServiceScopeFactory ScopeFactory
@using TZHJ.Core.Logging

<h1>操作日志</h1>

<div class="card">
    <div class="row" style="align-items:flex-end;">
        <div style="max-width:140px;"><label>工号</label><input @bind="_empId" /></div>
        <div style="max-width:160px;">
            <label>动作</label>
            <select @bind="_action">
                <option value="">全部</option>
                @foreach (var (val, label) in LogText.Actions)
                {
                    <option value="@val">@label</option>
                }
            </select>
        </div>
        <div style="max-width:130px;">
            <label>状态</label>
            <select @bind="_status">
                <option value="">全部</option>
                <option value="Success">成功</option>
                <option value="Failed">失败</option>
            </select>
        </div>
        <div style="max-width:200px;"><label>起（含）</label><input type="datetime-local" @bind="_from" /></div>
        <div style="max-width:200px;"><label>止（含）</label><input type="datetime-local" @bind="_to" /></div>
        <div style="flex:0 0 auto;">
            <button disabled="@_busy" @onclick="Search">查询</button>
            <button class="ghost" @onclick="Clear">清空</button>
        </div>
    </div>
</div>

<div class="card">
    <h2>共 @_total 条 · 第 @_page 页</h2>
    <table>
        <thead>
            <tr><th>时间</th><th>工号</th><th>动作</th><th>状态</th><th>流程/组</th><th>批次</th><th title="本次操作影响的数据行数；登录、账号管理等操作不涉及数据行，显示为 —">影响行数</th><th>详情</th><th>IP</th></tr>
        </thead>
        <tbody>
            @foreach (var x in _items)
            {
                <tr>
                    <td>@LocalTime(x.Timestamp)</td>
                    <td>@x.EmployeeId</td>
                    <td>@(x.Action == "Submit" ? LogText.SubmitLabel(x.Flow, LogText.IsResubmit(x.Payload)) : ActionText(x.Action))</td>
                    <td>
                        @if (x.Status == "Failed") { <span class="pill off">失败</span> }
                        else { <span class="pill ok">成功</span> }
                    </td>
                    <td>@(x.Flow is null ? "" : FlowText(x.Flow.Value)) @x.GroupName</td>
                    <td>@x.BatchId</td>
                    <td>@(x.ImpactCount == 0 ? "—" : x.ImpactCount.ToString())</td>
                    <td class="muted">@DetailText(x)</td>
                    <td class="muted">@x.ClientIp</td>
                </tr>
            }
            @if (_items.Count == 0)
            {
                <tr><td colspan="9" class="muted">无记录。</td></tr>
            }
        </tbody>
    </table>
    <div style="margin-top:14px;">
        <button class="ghost" disabled="@(_busy || _page <= 1)" @onclick="Prev">上一页</button>
        <button class="ghost" disabled="@(_busy || _page * _pageSize >= _total)" @onclick="Next">下一页</button>
    </div>
</div>

@code {
    private List<AdminLogEntry> _items = new();
    private int _total;
    private int _page = 1;
    private const int _pageSize = 50;
    private bool _busy;

    private string _empId = "", _action = "", _status = "";
    private DateTime? _from, _to;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _busy = true;
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var svc = scope.ServiceProvider.GetRequiredService<IAdminService>();
            var resp = await svc.QueryLogsAsync(
                NullIfBlank(_empId), NullIfBlank(_action), NullIfBlank(_status),
                _from?.ToString("yyyy-MM-ddTHH:mm:ss", CultureInfo.InvariantCulture),
                _to?.ToString("yyyy-MM-ddTHH:mm:ss", CultureInfo.InvariantCulture),
                _page, _pageSize);
            _items = resp.Items;
            _total = resp.Total;
        }
        finally { _busy = false; }
    }

    private async Task Search() { _page = 1; await Load(); }

    private async Task Clear()
    {
        _empId = _action = _status = "";
        _from = _to = null;
        _page = 1;
        await Load();
    }

    private async Task Prev() { if (_page > 1) { _page--; await Load(); } }
    private async Task Next() { if (_page * _pageSize < _total) { _page++; await Load(); } }

    private static string? NullIfBlank(string s) => string.IsNullOrWhiteSpace(s) ? null : s;
    private static string FlowText(FlowType f) => f == FlowType.Pricing ? "核价" : "挑图";

    private static string ActionText(string action) => LogText.ActionLabel(action);

    // 「详情」= 把历史英文 payload 翻译美化成中文；payload 为空时按动作合成一句可读描述。
    private static string DetailText(AdminLogEntry x) =>
        string.IsNullOrWhiteSpace(x.Payload) ? SynthDetail(x) : LogText.Prettify(x.Payload!);

    private static string SynthDetail(AdminLogEntry x) => x.Action switch
    {
        "Login" => "登录成功",
        "AdminLogin" => "后台登录成功",
        "ChangePassword" => "密码修改成功",
        "Ingest" => $"导入 {x.ImpactCount} 行{FlowGroupSuffix(x)}",
        _ => "",
    };

    private static string FlowGroupSuffix(AdminLogEntry x)
    {
        var parts = new List<string>();
        if (x.Flow is not null) parts.Add(FlowText(x.Flow.Value));
        if (!string.IsNullOrWhiteSpace(x.GroupName)) parts.Add(x.GroupName!);
        return parts.Count == 0 ? "" : $"（{string.Join("/", parts)}）";
    }
    private static string LocalTime(DateTime utc) =>
        DateTime.SpecifyKind(utc, DateTimeKind.Utc).ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture);
}
