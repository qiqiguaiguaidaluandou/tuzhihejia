<Window x:Class="TZHJ.App.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="更改密码"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        FontFamily="Microsoft YaHei" FontSize="13">
  <StackPanel Margin="30,26,30,26">
    <TextBlock Text="更改密码" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
    <TextBlock Text="当前密码由 DHR 统一管理，此处为预留入口。"
               Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap" />

    <TextBlock Text="当前密码" Foreground="{StaticResource TextSecondary}" Margin="0,20,0,5" />
    <PasswordBox x:Name="OldBox" Height="40" />

    <TextBlock Text="新密码" Foreground="{StaticResource TextSecondary}" Margin="0,14,0,5" />
    <PasswordBox x:Name="NewBox" Height="40" />

    <TextBlock Text="确认新密码" Foreground="{StaticResource TextSecondary}" Margin="0,14,0,5" />
    <PasswordBox x:Name="ConfirmBox" Height="40" />

    <TextBlock x:Name="ErrorText" Foreground="{StaticResource Red}" FontSize="12" TextWrapping="Wrap"
               Margin="0,12,0,0" Visibility="Collapsed" />

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
      <Button Content="取消" Width="88" Height="40" IsCancel="True" Margin="0,0,10,0" />
      <Button Content="确定" Width="88" Height="40" Style="{StaticResource BtnPrimary}"
              IsDefault="True" Click="OnConfirm" />
    </StackPanel>
  </StackPanel>
</Window>
