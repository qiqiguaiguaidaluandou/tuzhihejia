<UserControl x:Class="TZHJ.App.Views.ExceptionResolveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fi="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
             Loaded="OnLoaded" FontFamily="Microsoft YaHei" FontSize="13">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- 页头 -->
    <Border Grid.Row="0" Background="{StaticResource HeaderBg}" BorderBrush="{StaticResource Border1}" BorderThickness="0,0,0,1" Padding="16,10">
      <DockPanel>
        <Button DockPanel.Dock="Left" Style="{StaticResource BtnSubtle}" Command="{Binding BackCommand}">
          <StackPanel Orientation="Horizontal">
            <fi:SymbolIcon Symbol="ChevronLeft" FontSize="16" Foreground="{StaticResource Accent}" VerticalAlignment="Center" />
            <TextBlock Text="返回异常列表" Margin="4,0,0,0" Foreground="{StaticResource Accent}" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" />
      </DockPanel>
    </Border>

    <!-- 信息条 + 操作 -->
    <Border Grid.Row="1" Style="{StaticResource Card}" Margin="24,14,24,8" Padding="14,10">
      <DockPanel LastChildFill="False">
        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
          <TextBlock>
            <Run Text="来源批次：" Foreground="{StaticResource TextMuted}" /><Run Text="{Binding SourceBatchText, Mode=OneWay}" FontWeight="SemiBold" />
            <Run Text="    异常原因：" Foreground="{StaticResource TextMuted}" /><Run Text="{Binding ReasonText, Mode=OneWay}" Foreground="{StaticResource Orange}" />
          </TextBlock>
          <TextBlock Text="{Binding GateText}" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" MaxWidth="640" HorizontalAlignment="Left" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Button Command="{Binding OpenFolderCommand}"
                  Visibility="{Binding CanResolve, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
              <fi:SymbolIcon Symbol="FolderOpen" FontSize="15" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
              <TextBlock Text="打开来源批次（含图纸）" Margin="6,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <!-- 重新获取图纸：放在「重新回传」前面（左侧）。PLM 当时无图、之后补上时用。 -->
          <Button Margin="8,0,0,0" Command="{Binding RefetchDrawingCommand}"
                  Visibility="{Binding CanRefetch, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
              <fi:SymbolIcon Symbol="ArrowClockwise" FontSize="15" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
              <TextBlock Text="重新获取图纸" Margin="6,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Margin="8,0,0,0" Style="{StaticResource BtnPrimary}" Command="{Binding UploadCommand}"
                  Visibility="{Binding CanResolve, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
              <fi:SymbolIcon Symbol="ArrowUpload" FontSize="15" Foreground="White" VerticalAlignment="Center" />
              <TextBlock Text="{Binding SubmitButtonText}" Margin="6,0,0,0" Foreground="White" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- 内容：可补处理 → 全字段表单；否则 → 提示 -->
    <Grid Grid.Row="2" Margin="24,0,24,20">
      <!-- 全字段竖排表单（字段行由代码后置按 schema 生成；DataContext=该行的编辑投影 Row） -->
      <Border CornerRadius="10" Background="White" BorderBrush="{StaticResource Border1}" BorderThickness="1"
              SnapsToDevicePixels="True"
              Visibility="{Binding CanResolve, Converter={StaticResource BoolToVis}}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
          <StackPanel x:Name="FormHost" DataContext="{Binding Row}" />
        </ScrollViewer>
      </Border>

      <!-- 不可补处理提示 -->
      <Border CornerRadius="10" Background="White" BorderBrush="{StaticResource Border1}" BorderThickness="1"
              Visibility="{Binding CanResolve, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
          <fi:SymbolIcon Symbol="Warning" FontSize="32" Foreground="{StaticResource Orange}" HorizontalAlignment="Center" />
          <TextBlock Text="{Binding GateText}" Foreground="{StaticResource TextSecondary}" Margin="0,12,0,0"
                     TextWrapping="Wrap" MaxWidth="420" TextAlignment="Center" />
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</UserControl>
