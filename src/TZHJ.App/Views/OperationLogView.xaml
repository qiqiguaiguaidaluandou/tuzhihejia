<UserControl x:Class="TZHJ.App.Views.OperationLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fi="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
             xmlns:b="clr-namespace:TZHJ.App.Behaviors"
             FontFamily="Microsoft YaHei" FontSize="13">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource HeaderBg}" BorderBrush="{StaticResource Border1}" BorderThickness="0,0,0,1" Padding="24,16">
      <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}" />
    </Border>

    <DockPanel Grid.Row="1" Margin="24,14,24,8" LastChildFill="False">
      <TextBlock DockPanel.Dock="Left" Text="仅显示本人操作记录（回传 / 补回传）。" Foreground="{StaticResource TextMuted}"
                 VerticalAlignment="Center" Margin="0,0,10,0" />
      <Button DockPanel.Dock="Right" Command="{Binding RefreshCommand}">
        <StackPanel Orientation="Horizontal">
          <fi:SymbolIcon Symbol="ArrowClockwise" FontSize="15" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
          <TextBlock Text="刷新" Margin="6,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
    </DockPanel>

    <!-- 操作日志列表（圆角卡片框） -->
    <Border Grid.Row="2" Margin="24,0,24,20" CornerRadius="10" Background="White"
            BorderBrush="{StaticResource Border1}" BorderThickness="1" SnapsToDevicePixels="True">
      <DataGrid b:CornerClip.Radius="10" BorderThickness="0" ItemsSource="{Binding Items}" IsReadOnly="True">
        <DataGrid.Columns>
          <DataGridTextColumn Header="时间" Binding="{Binding OperatedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="160" />
          <DataGridTextColumn Header="操作按钮" Binding="{Binding Operation}" Width="160" />
          <DataGridTextColumn Header="表单名称" Binding="{Binding FormName}" Width="*" />
          <DataGridTextColumn Header="操作电脑IP" Binding="{Binding ClientIp}" Width="140" />
        </DataGrid.Columns>
      </DataGrid>
    </Border>
  </Grid>
</UserControl>
