<Window x:Class="TZHJ.App.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fi="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
        Title="图纸核价 / 机加工挑图系统"
        Height="800" Width="1220"
        WindowStartupLocation="CenterScreen"
        FontFamily="Microsoft YaHei" FontSize="13"
        Background="{StaticResource WindowBg}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="52" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- 应用头（白色，区别于系统标题栏） -->
    <Border Grid.Row="0" Background="{StaticResource HeaderBg}" BorderBrush="{StaticResource Border1}" BorderThickness="0,0,0,1">
      <DockPanel LastChildFill="False" Margin="18,0">
        <fi:SymbolIcon DockPanel.Dock="Left" Symbol="DocumentTable" FontSize="22"
                       Foreground="{StaticResource Accent}" VerticalAlignment="Center" />
        <TextBlock DockPanel.Dock="Left" Text="图纸核价 / 机加工挑图系统" FontSize="14" FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="10,0,0,0" />
        <!-- 右上角账户菜单：个人资料 + 更改密码 + 退出登录 -->
        <Grid DockPanel.Dock="Right" VerticalAlignment="Center">
          <ToggleButton x:Name="AccountToggle" Style="{StaticResource AccountChip}">
            <StackPanel Orientation="Horizontal">
              <Border Width="28" Height="28" CornerRadius="14" Background="{StaticResource Accent}">
                <TextBlock Text="{Binding Avatar}" Foreground="White" FontSize="13" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <TextBlock Text="{Binding UserName}" Margin="9,0,5,0" VerticalAlignment="Center"
                         Foreground="{StaticResource TextBrush}" FontSize="13" />
              <fi:SymbolIcon Symbol="ChevronDown" FontSize="12" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
            </StackPanel>
          </ToggleButton>

          <Popup IsOpen="{Binding IsChecked, ElementName=AccountToggle}" StaysOpen="False"
                 Placement="Bottom" HorizontalOffset="-168" VerticalOffset="6"
                 AllowsTransparency="True" PopupAnimation="Fade">
            <!-- 圆角描边卡片（不用 DropShadowEffect，避免透明弹窗下渲染成黑边） -->
            <Border Width="264" CornerRadius="12" Background="White"
                    BorderBrush="{StaticResource Border2}" BorderThickness="1" Margin="0">
              <StackPanel>
                <!-- 个人资料头部 -->
                <StackPanel Margin="18,18,18,14">
                  <Border Width="46" Height="46" CornerRadius="23" Background="{StaticResource Accent}" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding Avatar}" Foreground="White" FontSize="19" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <TextBlock Text="{Binding UserName}" FontSize="15" FontWeight="SemiBold"
                             Foreground="{StaticResource TextBrush}" Margin="0,11,0,3" />
                  <TextBlock Foreground="{StaticResource TextMuted}" FontSize="12">
                    <Run Text="工号 " /><Run Text="{Binding EmployeeId, Mode=OneWay}" />
                  </TextBlock>
                </StackPanel>

                <Border Height="1" Background="{StaticResource Border1}" />

                <!-- 个人资料明细（不含权限） -->
                <Grid Margin="18,13,18,13">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="部门" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,7" />
                  <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Department}" Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,0,0,7" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="岗位" Foreground="{StaticResource TextMuted}" FontSize="12" />
                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Position}" Foreground="{StaticResource TextBrush}" FontSize="12" TextWrapping="Wrap" />
                </Grid>

                <Border Height="1" Background="{StaticResource Border1}" />

                <!-- 操作 -->
                <Button Style="{StaticResource MenuItemButton}" Click="OnChangePassword" Margin="0,6,0,0">
                  <StackPanel Orientation="Horizontal">
                    <fi:SymbolIcon Symbol="LockClosed" FontSize="16" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                    <TextBlock Text="更改密码" Margin="11,0,0,0" VerticalAlignment="Center" />
                  </StackPanel>
                </Button>
                <Button Style="{StaticResource MenuItemButton}" Click="OnLogout" Margin="0,0,0,6">
                  <StackPanel Orientation="Horizontal">
                    <fi:SymbolIcon Symbol="SignOut" FontSize="16" Foreground="{StaticResource Red}" VerticalAlignment="Center" />
                    <TextBlock Text="退出登录" Margin="11,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Red}" />
                  </StackPanel>
                </Button>
              </StackPanel>
            </Border>
          </Popup>
        </Grid>
      </DockPanel>
    </Border>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="228" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- 侧边栏：直接映射本地文件夹（两流程功能区 + 系统） -->
      <Border Grid.Column="0" Background="{StaticResource SidebarBg}" BorderBrush="{StaticResource Border1}" BorderThickness="0,0,1,0">
        <DockPanel>
          <TextBlock DockPanel.Dock="Bottom" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" FontSize="11"
                     Margin="14,8,14,12"
                     Text="「待处理 / 已处理 / 异常待跟进」即映射本机文件夹，软件是文件夹的视图。图纸由操作员自行到文件夹用本机软件查看。" />
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Groups}" Margin="10,12">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="{Binding Header}" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold"
                               Margin="10,4,0,4" />
                    <ItemsControl ItemsSource="{Binding Items}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Button Style="{StaticResource NavButton}"
                                  Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}">
                            <StackPanel Orientation="Horizontal">
                              <fi:SymbolIcon Symbol="{Binding Icon}" Style="{StaticResource NavIcon}" />
                              <TextBlock Text="{Binding Title}" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <!-- 内容区：当前页（VM → View 由 App.xaml 模板映射） -->
      <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" />
    </Grid>

    <!-- Toast 宿主：覆盖在最上层、底部居中、不拦截点击 -->
    <StackPanel x:Name="ToastHost" Grid.RowSpan="2" Panel.ZIndex="100"
                VerticalAlignment="Bottom" HorizontalAlignment="Center"
                IsHitTestVisible="False" Margin="0,0,0,28" />
  </Grid>
</Window>
