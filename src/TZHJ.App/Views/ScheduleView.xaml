<UserControl x:Class="TZHJ.App.Views.ScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Microsoft YaHei" FontSize="13">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource HeaderBg}" BorderBrush="{StaticResource Border1}" BorderThickness="0,0,0,1" Padding="24,16">
      <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}" />
    </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="24,16">
        <TextBlock Text="图纸核价" FontWeight="SemiBold" Margin="0,0,0,8" />
        <DataGrid ItemsSource="{Binding PricingRows}" IsReadOnly="True" Margin="0,0,0,22">
          <DataGrid.Columns>
            <DataGridTextColumn Header="窗口名" Binding="{Binding Name}" Width="120" />
            <DataGridTextColumn Header="采集区间" Binding="{Binding RangeText}" Width="*" />
            <DataGridTextColumn Header="触发时刻" Binding="{Binding TriggerText}" Width="220" />
            <DataGridTextColumn Header="启用" Binding="{Binding EnabledText}" Width="80" />
          </DataGrid.Columns>
        </DataGrid>

        <TextBlock Text="机加工挑图" FontWeight="SemiBold" Margin="0,0,0,8" />
        <DataGrid ItemsSource="{Binding DrawingRows}" IsReadOnly="True">
          <DataGrid.Columns>
            <DataGridTextColumn Header="窗口名" Binding="{Binding Name}" Width="120" />
            <DataGridTextColumn Header="采集区间" Binding="{Binding RangeText}" Width="*" />
            <DataGridTextColumn Header="触发时刻" Binding="{Binding TriggerText}" Width="220" />
            <DataGridTextColumn Header="启用" Binding="{Binding EnabledText}" Width="80" />
          </DataGrid.Columns>
        </DataGrid>

        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" Margin="0,14,0,0"
                   Text="触发挂在客户端登录态上：登录后按规则触发，并做登录补拉（补齐本该有但本地缺的窗口）。两流程时间窗各自独立、可配置。" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
