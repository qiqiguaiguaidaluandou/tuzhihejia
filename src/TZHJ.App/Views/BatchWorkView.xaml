<UserControl x:Class="TZHJ.App.Views.BatchWorkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fi="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
             xmlns:b="clr-namespace:TZHJ.App.Behaviors"
             Loaded="OnLoaded" FontFamily="Microsoft YaHei" FontSize="13">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- 页头 -->
    <Border Grid.Row="0" Background="{StaticResource HeaderBg}" BorderBrush="{StaticResource Border1}" BorderThickness="0,0,0,1" Padding="16,10">
      <DockPanel>
        <Button DockPanel.Dock="Left" Style="{StaticResource BtnSubtle}" Command="{Binding BackCommand}">
          <StackPanel Orientation="Horizontal">
            <fi:SymbolIcon Symbol="ChevronLeft" FontSize="16" Foreground="{StaticResource Accent}" VerticalAlignment="Center" />
            <TextBlock Text="返回" Margin="4,0,0,0" Foreground="{StaticResource Accent}" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" />
      </DockPanel>
    </Border>

    <!-- 信息条 + 操作 -->
    <Border Grid.Row="1" Style="{StaticResource Card}" Margin="24,14,24,8" Padding="14,10">
      <DockPanel LastChildFill="False">
        <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,18,0">
          <Run Text="进度：" Foreground="#9AA1AB" /><Run Text="{Binding ProgressText, Mode=OneWay}" FontWeight="SemiBold" />
        </TextBlock>
        <TextBlock DockPanel.Dock="Left" Text="{Binding FolderPathText}" Foreground="{StaticResource TextMuted}"
                   FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,10,0"
                   TextTrimming="CharacterEllipsis" MaxWidth="380" />
        <Button DockPanel.Dock="Left" Command="{Binding OpenFolderCommand}">
          <StackPanel Orientation="Horizontal">
            <fi:SymbolIcon Symbol="FolderOpen" FontSize="15" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
            <TextBlock Text="打开文件夹（含图纸）" Margin="6,0,0,0" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <Button DockPanel.Dock="Right" Style="{StaticResource BtnPrimary}" Command="{Binding SubmitCommand}"
                Visibility="{Binding IsReadOnly, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
          <StackPanel Orientation="Horizontal">
            <fi:SymbolIcon Symbol="ArrowUpload" FontSize="15" Foreground="White" VerticalAlignment="Center" />
            <TextBlock Text="{Binding SubmitButtonText}" Margin="6,0,0,0" Foreground="White" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button DockPanel.Dock="Right" Command="{Binding SaveCommand}"
                Visibility="{Binding IsReadOnly, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
          <StackPanel Orientation="Horizontal">
            <fi:SymbolIcon Symbol="Save" FontSize="15" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
            <TextBlock Text="暂存" Margin="6,0,0,0" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </DockPanel>
    </Border>

    <!-- 可编辑网格（列由字段 schema 在代码后置动态生成），圆角卡片框 -->
    <Border Grid.Row="2" Margin="24,0,24,20" CornerRadius="10" Background="White"
            BorderBrush="{StaticResource Border1}" BorderThickness="1" SnapsToDevicePixels="True">
      <DataGrid x:Name="Grid" b:CornerClip.Radius="10" BorderThickness="0" RowHeight="44" ItemsSource="{Binding Rows}" />
    </Border>
  </Grid>
</UserControl>
