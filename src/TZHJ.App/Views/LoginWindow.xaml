<Window x:Class="TZHJ.App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fi="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
        Title="图纸核价 / 机加工挑图系统 — 登录"
        Height="600" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Microsoft YaHei" FontSize="13"
        FocusManager.FocusedElement="{Binding ElementName=EmployeeBox}">

  <!-- 背景：深蓝 → 强调蓝 斜向渐变 -->
  <Grid>
    <Grid.Background>
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0F1F3D" Offset="0" />
        <GradientStop Color="#1E3A6B" Offset="0.55" />
        <GradientStop Color="#2563EB" Offset="1" />
      </LinearGradientBrush>
    </Grid.Background>

    <!-- 登录卡片 -->
    <Border Background="White" CornerRadius="18" Width="392" VerticalAlignment="Center"
            HorizontalAlignment="Center" Padding="40,38">
      <Border.Effect>
        <DropShadowEffect Color="#33000000" BlurRadius="40" ShadowDepth="6" Direction="270" />
      </Border.Effect>
      <StackPanel>
        <!-- Logo -->
        <Border Width="68" Height="68" CornerRadius="18" Background="{StaticResource AccentLight}" HorizontalAlignment="Center">
          <fi:SymbolIcon Symbol="DocumentTable" FontSize="36" Foreground="{StaticResource Accent}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <TextBlock Text="图纸核价 / 机加工挑图系统" FontSize="21" FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,18,0,6" />
        <TextBlock Text="PC 客户端 · 本机固定操作员&#x0a;登录身份后续由 DHR 统一提供（SSO）"
                   Foreground="{StaticResource TextMuted}" FontSize="12.5" TextAlignment="Center"
                   LineHeight="20" Margin="0,0,0,26" />

        <TextBlock Text="工号" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6" />
        <TextBox x:Name="EmployeeBox" Height="42" FontSize="14"
                 Text="{Binding EmployeeId, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="密码" Foreground="{StaticResource TextSecondary}" Margin="0,16,0,6" />
        <PasswordBox x:Name="PasswordBox" Height="42" FontSize="14" PasswordChanged="OnPasswordChanged" />

        <TextBlock Text="{Binding Error}" Foreground="{StaticResource Red}" FontSize="12" TextWrapping="Wrap"
                   Margin="0,12,0,0"
                   Visibility="{Binding Error, Converter={StaticResource StringToVis}}" />

        <!-- IsDefault：回车即登录 -->
        <Button Content="登 录" Style="{StaticResource BtnPrimary}" Height="46" FontSize="15" Margin="0,24,0,0"
                IsDefault="True"
                Command="{Binding LoginCommand}"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
        <TextBlock Text="— 或 — 使用 DHR 单点登录（接入后启用）"
                   Foreground="{StaticResource TextMuted}" FontSize="11.5" HorizontalAlignment="Center" Margin="0,18,0,0" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
